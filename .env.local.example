# Copy to .env.local and fill in values

# Admin portal password — set to a strong password
ADMIN_PASSWORD=changeme

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# MongoDB connection — URL-encode special chars in the password (@ -> %40)
MONGODB_URI=mongodb://user:pass@127.0.0.1:27017/personal-portfolio

# Legacy SQLite path — only used by `npm run db:seed` to migrate old data
DATABASE_URL=./data/portfolio.db

# API key for posting blogs via the REST API
# Generate with: openssl rand -hex 32
# Usage: Authorization: Bearer <key>
API_SECRET_KEY=your-api-key-here
